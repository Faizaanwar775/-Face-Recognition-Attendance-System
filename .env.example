# Copy this file to `.env` and adjust values as needed.
# The app reads these via os.getenv() in src/config.py; a .env loader
# (e.g. `python-dotenv`) is NOT wired in by default to keep dependencies
# minimal -- either export these in your shell, or add `python-dotenv`
# yourself if you prefer a .env workflow.

KHIZEX_CAMERA_INDEX=0
KHIZEX_FRAME_WIDTH=640
KHIZEX_FRAME_HEIGHT=480
KHIZEX_TARGET_FPS=30

KHIZEX_FRAME_QUEUE_SIZE=1
KHIZEX_RESULT_QUEUE_SIZE=5

KHIZEX_DETECTION_MODEL=hog
KHIZEX_EMBEDDING_MODEL=small
KHIZEX_NUM_JITTERS=1
KHIZEX_PROCESS_EVERY_N=2

KHIZEX_MATCH_THRESHOLD=0.55

KHIZEX_EAR_THRESHOLD=0.21
KHIZEX_EAR_CONSEC_FRAMES=2
KHIZEX_REQUIRED_BLINKS=1
KHIZEX_LIVENESS_WINDOW_SECONDS=8.0
KHIZEX_TRACK_MAX_MISSED=15
KHIZEX_TRACK_IOU_THRESHOLD=0.3

KHIZEX_ENROLLMENT_FRAMES=15
KHIZEX_LOG_COOLDOWN_SECONDS=30.0

KHIZEX_EMBEDDING_WORKERS=2
